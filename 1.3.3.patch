+                'expected_waffle_tests': None,
+            },
+            {
+                'name': 'percent cookie true',
+                'flag_kwargs': {'name': 'test_flag', 'percent': 50.0},
+                'request': make_request(cookies={'dwf_test_flag': 'True'}),
+                'expected': True,
